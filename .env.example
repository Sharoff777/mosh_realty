# ── Vercel Blob ───────────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# ── SMTP (Gmail) ──────────────────────────────────────────────
# Use an App Password, NOT your Gmail login password.
# How to get one: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Recipients ────────────────────────────────────────────────
# All 3 are optional — only non-empty values are used
RECIPIENT_EMAIL_1=mohsin.myventures@gmail.com
RECIPIENT_EMAIL_2=aman.myventures@gmail.com
RECIPIENT_EMAIL_3=sharoff.myventures@gmail.com
