{
  "version": 2,
  "builds": [
    { "src": "api/upload.js",  "use": "@vercel/node" },
    { "src": "api/submit.js",  "use": "@vercel/node" },
    { "src": "public/**",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/upload",  "dest": "/api/upload.js" },
    { "src": "/api/submit",  "dest": "/api/submit.js" },
    { "src": "/(.*)",        "dest": "/public/$1" }
  ]
}
